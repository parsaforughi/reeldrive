# Telegram (required)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Instagram account for the bot (required for stories & most features)
INSTAGRAM_USERNAME=your_ig_username
INSTAGRAM_PASSWORD=your_ig_password

# Optional: path for persisted instagrapi session (default: sessions/instagram.json)
INSTAGRAM_SESSION_PATH=sessions/instagram.json

# Bot display name in messages
BOT_NAME=Regram Pro
