# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token

# Apify — direct download (Instagram Scraper actor)
APIFY_TOKEN=your_apify_api_token
APIFY_ACTOR=apify~instagram-scraper
APIFY_TIMEOUT_SECONDS=120

# Service IG — optional: profile/stories/highlights only
INSTAGRAM_USERNAME=your_service_ig_account
INSTAGRAM_PASSWORD=your_password
INSTAGRAM_SESSION_PATH=sessions/service.json

# Bridge IG — DM @reeldrivebot → Telegram (only this is required on Railway):
INSTAGRAM_BRIDGE_SESSION_ID=
# Required on Railway for IG DMs (467): residential http proxy
# INSTAGRAM_PROXY=http://user:pass@host:port
INSTAGRAM_PROXY=
INSTAGRAM_BRIDGE_ENABLED=true
INSTAGRAM_BRIDGE_DISPLAY=reeldrivebot
INSTAGRAM_BRIDGE_SESSION_PATH=sessions/bridge.json

# Database — use Railway PostgreSQL (recommended) or SQLite + Volume on /app/data
# Postgres: add PostgreSQL plugin in Railway; DATABASE_URL is set automatically
DATABASE_URL=sqlite+aiosqlite:///./data/reeldrive.db

BOT_NAME=Reeldrive
VERIFICATION_CODE_TTL_MINUTES=15
BRIDGE_POLL_INTERVAL_SECONDS=2
MAX_ZIP_POSTS=100
MAX_FOLLOWING_LIST=10000
# Apify actor for /following (no IG login needed, public accounts only)
APIFY_FOLLOWING_ACTOR=scraping_solutions~instagram-scraper-followers-following-no-cookies

# Telegram Stars — Pro subscription
STARS_PAYMENT_ENABLED=true
PRO_STARS_PRICE=250
PRO_SUBSCRIPTION_DAYS=30
PAYMENT_SUPPORT_USERNAME=reeldrive

# Following-list: must join these channels; every account looked up costs
# a token bought via manual card-to-card (no free pages).
FOLLOWING_REQUIRED_CHANNELS=@abolfazl_nouriii,@reeldirve,@license_club
FOLLOWING_PAGE_PRICE_TOMAN=15000
FOLLOWING_FREE_PAGES=0
# Cards rotate every FOLLOWING_CARDS_ROTATE_EVERY confirmed token purchases.
# Only the first is active for now — add more comma-separated whenever
# rotation should resume.
FOLLOWING_SUPPORT_CARDS=6219861462108209
FOLLOWING_CARD_HOLDER_NAME=احمد عابدزاده
FOLLOWING_CARDS_ROTATE_EVERY=15
ADMIN_TELEGRAM_IDS=99686187,8989258776

# AI post analysis — OpenAI (ChatGPT API)
OPENAI_API_KEY=sk-your-openai-key
AI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4o
AI_VISION_ENABLED=true
AI_VIDEO_FRAMES_ENABLED=true
AI_VIDEO_FRAME_COUNT=8
AI_VIDEO_MAX_MB=25
AI_ANALYSIS_REQUIRES_PRO=true
AI_FREE_MONTHLY_LIMIT=0
AI_PRO_MONTHLY_LIMIT=80
AI_UNLIMITED_USERNAMES=parsaforughi
AI_UNLIMITED_TELEGRAM_IDS=99686187
AI_PAGE_BENCHMARK_ENABLED=true
AI_PAGE_POSTS_FOR_AVG=12

# Admin dashboard — سرویس Web روی Railway (reeldrive.up.railway.app)
DASHBOARD_PASSWORD=your-strong-password
DASHBOARD_SECRET=random-secret-string
# محلی: 8080 — روی Railway از متغیر PORT پلتفرم استفاده می‌شود
DASHBOARD_PORT=8080
