# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token

# Apify — direct download (Instagram Scraper actor)
APIFY_TOKEN=your_apify_api_token
APIFY_ACTOR=apify~instagram-scraper
APIFY_TIMEOUT_SECONDS=120

# Service IG — optional: profile/stories/highlights only
INSTAGRAM_USERNAME=your_service_ig_account
INSTAGRAM_PASSWORD=your_password
INSTAGRAM_SESSION_PATH=sessions/service.json

# Bridge IG — verification codes & DM relay (can be same account)
INSTAGRAM_BRIDGE_USERNAME=
INSTAGRAM_BRIDGE_PASSWORD=
INSTAGRAM_BRIDGE_SESSION_PATH=sessions/bridge.json
# یوزرنیم عمومی IG که کاربر کد را به آن DM می‌زند
INSTAGRAM_BRIDGE_DISPLAY=reeldrivebot

# Database (Railway Postgres: postgresql+asyncpg://...)
DATABASE_URL=sqlite+aiosqlite:///./data/reeldrive.db

BOT_NAME=Reeldrive
VERIFICATION_CODE_TTL_MINUTES=15
BRIDGE_POLL_INTERVAL_SECONDS=20
MAX_ZIP_POSTS=100

# Admin dashboard — سرویس Web روی Railway (reeldrive.up.railway.app)
DASHBOARD_PASSWORD=your-strong-password
DASHBOARD_SECRET=random-secret-string
# محلی: 8080 — روی Railway از متغیر PORT پلتفرم استفاده می‌شود
DASHBOARD_PORT=8080
